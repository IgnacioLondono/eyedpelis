# Copia a .env en Portainer o en el servidor para el stack

# TMDB
TMDB_API_KEY=tu_api_key_de_tmdb

# Auth Eyedpelis
JWT_SECRET=un-secreto-largo-y-aleatorio
ADMIN_USER=eyedpelis
ADMIN_PASSWORD=cambia-esta-contraseña
AUTH_ENABLED=true
CLIENT_URL=https://eyedmovies.eyedcomun.me

# qBittorrent — URL INTERNA Docker (no uses :8787 del host salvo host.docker.internal)
# LinuxServer qBittorrent suele escuchar en 8080 dentro del contenedor
QBITTORRENT_URL=http://qbittorrent:8080
QBITTORRENT_USER=admin
QBITTORRENT_PASS=adminadmin

# Prowlarr (API key en Prowlarr → Settings → General)
PROWLARR_URL=http://prowlarr:9696
PROWLARR_API_KEY=

# Jackett (alternativa)
JACKETT_URL=http://jackett:9117
JACKETT_API_KEY=

# Jellyfin (opcional)
JELLYFIN_URL=http://jellyfin:8096
JELLYFIN_API_KEY=
