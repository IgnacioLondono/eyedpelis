# Variables del stack Eyedpelis (Portainer → Environment o archivo .env)

# Rutas en el NAS (ajusta si tu disco es otro)
MEDIA_PATH=/srv/dev-disk-by-uuid-a5b4e34c-5e9b-430c-93ad-0473fe6143d2/data/Videos
DOWNLOADS_PATH=/srv/dev-disk-by-uuid-a5b4e34c-5e9b-430c-93ad-0473fe6143d2/data/Downloads

PUID=1000
PGID=1000
TZ=Europe/Madrid

# Eyedpelis
TMDB_API_KEY=
JWT_SECRET=un-secreto-largo-y-aleatorio
ADMIN_USER=eyedpelis
ADMIN_PASSWORD=cambia-esta-contraseña
AUTH_ENABLED=true
CLIENT_URL=https://eyedmovies.eyedcomun.me

# Puertos HOST (acceso desde el navegador). Internamente Eyedpelis usa prowlarr:9696, etc.
QBIT_HOST_PORT=18787
QBIT_TORRENT_PORT=16881
PROWLARR_HOST_PORT=19696
JACKETT_HOST_PORT=19117
FLARESOLVERR_HOST_PORT=18191

# qBittorrent Web UI: http://TU_IP:18787
# qBittorrent — OBLIGATORIO (misma contraseña que la Web UI http://TU_IP:18787)
QBITTORRENT_USER=admin
QBITTORRENT_PASS=adminadmin

# Copiar tras el primer arranque desde cada Web UI
PROWLARR_API_KEY=
JACKETT_API_KEY=

# Jellyfin externo (opcional, si sigue en otro stack)
JELLYFIN_URL=
JELLYFIN_API_KEY=
